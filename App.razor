<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <ErrorBoundary @ref="errorBoundary">
            <ChildContent>
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="alert alert-danger m-3">
                    <h4><i class="bi bi-exclamation-triangle-fill"></i> Er is een fout opgetreden</h4>
                    <p><strong>Type:</strong> @ex.GetType().Name</p>
                    <p><strong>Melding:</strong> @ex.Message</p>
                    <details>
                        <summary>Technische details (klik om te openen)</summary>
                        <pre style="font-size: 0.75rem; white-space: pre-wrap;">@ex.StackTrace</pre>
                    </details>
                    <button class="btn btn-primary mt-2" @onclick="ResetError">Probeer opnieuw</button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <p role="alert">Sorry, there's nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private ErrorBoundary? errorBoundary;

    private void ResetError() => errorBoundary?.Recover();
}
