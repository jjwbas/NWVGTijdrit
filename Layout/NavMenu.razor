<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="">
            <img src="images/logo-nwvg.png" alt="NWVG Logo" style="height: 40px; margin-right: 8px;" onerror="this.style.display='none'" />
            <span>NWVG Tijdrit</span>
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill me-2"></i> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="deelnemers">
                <i class="bi bi-people-fill me-2"></i> Deelnemers
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tijdritten">
                <i class="bi bi-stopwatch-fill me-2"></i> Tijdritten
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="uitslagen">
                <i class="bi bi-trophy-fill me-2"></i> Uitslagen
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="instellingen">
                <i class="bi bi-gear me-2"></i> Instellingen
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
