# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.razor]
charset = utf-8

[*.cs]
charset = utf-8

[*.html]
charset = utf-8
indent_size = 2

[*.json]
indent_size = 2
