    private async Task OverschrijfBestaandeTijdrit()
    {
        toonDuplicaatModal = false;
        await VoerTijdritImportUit(maakOntbrekendeDeelnemersAan, true);
    }

    private async Task VoerTijdritImportUit(bool maakDeelnemersAan, bool overschrijf)
    {
        if (importTijdritData?.Tijdrit == null) return;

        try
        {
            // Stap 1: Maak mapping van oude naar nieuwe deelnemer IDs
            var idMapping = new Dictionary<Guid, Guid>();

            foreach (var info in importTijdritData.DeelnemerInfos ?? new List<DeelnemerInfo>())
            {
                var bestaand = alleDeelnemers.FirstOrDefault(d => 
                    d.Naam.Equals(info.Naam, StringComparison.OrdinalIgnoreCase));

                if (bestaand != null)
                {
                    idMapping[info.OrigineleId] = bestaand.Id;
                }
                else if (maakDeelnemersAan)
                {
                    // Maak nieuwe deelnemer aan
                    var nieuweDeelnemer = new Deelnemer
                    {
                        Id = Guid.NewGuid(),
                        Naam = info.Naam,
                        Categorie = info.Categorie,
                        StandaardRondes = 1
                    };
                    await DataService.SaveDeelnemerAsync(nieuweDeelnemer);
                    idMapping[info.OrigineleId] = nieuweDeelnemer.Id;
                    alleDeelnemers.Add(nieuweDeelnemer);
                }
            }

            // Stap 2: Verwerk tijdrit
            Guid nieuweTijdritId;

            if (overschrijf && bestaandeDuplicaatTijdrit != null)
            {
                // Verwijder bestaande resultaten
                var bestaandeResultaten = alleResultaten.Where(r => r.TijdritId == bestaandeDuplicaatTijdrit.Id).ToList();
                foreach (var r in bestaandeResultaten)
                {
                    await DataService.DeleteResultaatAsync(r.Id);
                }

                // Update tijdrit
                bestaandeDuplicaatTijdrit.RondeLengteKm = importTijdritData.Tijdrit.RondeLengteKm;
                bestaandeDuplicaatTijdrit.Beschrijving = importTijdritData.Tijdrit.Beschrijving;
                await DataService.SaveTijdritAsync(bestaandeDuplicaatTijdrit);
                nieuweTijdritId = bestaandeDuplicaatTijdrit.Id;
            }
            else
            {
                // Maak nieuwe tijdrit aan
                var nieuweTijdrit = new Tijdrit
                {
                    Id = Guid.NewGuid(),
                    Datum = importTijdritData.Tijdrit.Datum,
                    RondeLengteKm = importTijdritData.Tijdrit.RondeLengteKm,
                    Beschrijving = importTijdritData.Tijdrit.Beschrijving
                };
                await DataService.SaveTijdritAsync(nieuweTijdrit);
                nieuweTijdritId = nieuweTijdrit.Id;
            }

            // Stap 3: Importeer resultaten
            foreach (var resultaat in importTijdritData.Resultaten ?? new List<TijdritResultaat>())
            {
                if (idMapping.TryGetValue(resultaat.DeelnemerId, out Guid nieuweDeelnemerId))
                {
                    var nieuwResultaat = new TijdritResultaat
                    {
                        Id = Guid.NewGuid(),
                        TijdritId = nieuweTijdritId,
                        DeelnemerId = nieuweDeelnemerId,
                        Startvolgorde = resultaat.Startvolgorde,
                        AantalRondes = resultaat.AantalRondes,
                        Starttijd = resultaat.Starttijd,
                        Passagetijden = resultaat.Passagetijden?.ToList() ?? new List<TimeSpan>()
                    };
                    await DataService.SaveResultaatAsync(nieuwResultaat);
                }
            }

            importTijdritSucces = true;
            tijdritImportFileName = null;
            tijdritImportFileContent = null;
            importTijdritData = null;

            // Herlaad data
            await LaadStats();
            await LaadTijdrittenVoorExport();
        }
        catch (Exception ex)
        {
            importTijdritError = $"Import fout: {ex.Message}";
        }
    }

