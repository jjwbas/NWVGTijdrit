@page "/instellingen"
@using NWVGTijdrit.Data
@using System.Text.Json
@inject DataService DataService
@inject IJSRuntime JSRuntime

<PageTitle>Instellingen - NWVG Tijdrit</PageTitle>

<h1><i class="bi bi-gear"></i> Instellingen</h1>
<p class="lead">Beheer je data: maak backups, herstel data of reset de applicatie.</p>

<div class="row">
    @* Export sectie *@
    <div class="col-md-6 mb-4">
        <div class="card h-100 border-success">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-download"></i> Data exporteren (Backup)</h5>
            </div>
            <div class="card-body">
                <p>Download al je data als JSON-bestand. Bewaar dit bestand veilig om je data te kunnen herstellen.</p>

                @if (exportStats != null)
                {
                    <div class="alert alert-info">
                        <strong>Huidige data:</strong><br />
                        <i class="bi bi-people"></i> @exportStats.AantalDeelnemers deelnemers<br />
                        <i class="bi bi-stopwatch"></i> @exportStats.AantalTijdritten tijdritten<br />
                        <i class="bi bi-list-ol"></i> @exportStats.AantalResultaten resultaten<br />
                        <i class="bi bi-tags"></i> @exportStats.AantalCategorieen categorieën
                    </div>
                }

                <button class="btn btn-success w-100" @onclick="ExporteerData" disabled="@isExporting">
                    @if (isExporting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Exporteren...</span>
                    }
                    else
                    {
                        <i class="bi bi-download me-2"></i>
                        <span>Download backup</span>
                    }
                </button>

                @if (exportSucces)
                {
                    <div class="alert alert-success mt-3 mb-0">
                        <i class="bi bi-check-circle"></i> Backup gedownload!
                    </div>
                }
            </div>
        </div>
    </div>

    @* Import sectie *@
    <div class="col-md-6 mb-4">
        <div class="card h-100 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-upload"></i> Data importeren (Herstel)</h5>
            </div>
            <div class="card-body">
                <p>Herstel data uit een eerder geëxporteerd JSON-bestand. <strong>Let op:</strong> dit overschrijft alle huidige data!</p>

                <div class="mb-3">
                    <label class="form-label">Selecteer backup bestand:</label>
                    <InputFile OnChange="OnFileSelected" class="form-control" accept=".json" />
                </div>

                @if (selectedFileName != null)
                {
                    <div class="alert alert-warning">
                        <strong>Geselecteerd:</strong> @selectedFileName<br />
                        <small class="text-muted">Klik op "Importeer data" om te herstellen. Dit overschrijft alle huidige data!</small>
                    </div>

                    <button class="btn btn-primary w-100" @onclick="ImporteerData" disabled="@isImporting">
                        @if (isImporting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Importeren...</span>
                        }
                        else
                        {
                            <i class="bi bi-upload me-2"></i>
                            <span>Importeer data</span>
                        }
                    </button>
                }

                @if (importSucces)
                {
                    <div class="alert alert-success mt-3 mb-0">
                        <i class="bi bi-check-circle"></i> Data succesvol geïmporteerd!
                    </div>
                }

                @if (importError != null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-triangle"></i> @importError
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Losse tijdrit sectie *@
<div class="row mb-4">
    <div class="col-12">
        <h4 class="mt-4 mb-3"><i class="bi bi-stopwatch"></i> Losse tijdrit exporteren/importeren</h4>
    </div>

    @* Losse tijdrit export *@
    <div class="col-md-6 mb-4">
        <div class="card h-100 border-info">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-download"></i> Tijdrit exporteren</h5>
            </div>
            <div class="card-body">
                <p>Download één specifieke tijdrit met alle resultaten.</p>

                <div class="mb-3">
                    <label class="form-label">Selecteer tijdrit:</label>
                    <select class="form-select" @bind="geselecteerdeTijdritIdVoorExport">
                        <option value="">-- Kies een tijdrit --</option>
                        @foreach (var tijdrit in alleTijdritten.OrderByDescending(t => t.Datum))
                        {
                            <option value="@tijdrit.Id">@tijdrit.Datum.ToString("dd-MM-yyyy") @(!string.IsNullOrEmpty(tijdrit.Beschrijving) ? $"- {tijdrit.Beschrijving}" : "")</option>
                        }
                    </select>
                </div>

                @if (geselecteerdeTijdritIdVoorExport != Guid.Empty)
                {
                    var aantalResultaten = alleResultaten.Count(r => r.TijdritId == geselecteerdeTijdritIdVoorExport);
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Deze tijdrit heeft <strong>@aantalResultaten</strong> resultaten.
                    </div>
                }

                <button class="btn btn-info w-100" @onclick="ExporteerLosseTijdrit" 
                        disabled="@(geselecteerdeTijdritIdVoorExport == Guid.Empty || isExportingTijdrit)">
                    @if (isExportingTijdrit)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Exporteren...</span>
                    }
                    else
                    {
                        <i class="bi bi-download me-2"></i>
                        <span>Download tijdrit</span>
                    }
                </button>

                @if (exportTijdritSucces)
                {
                    <div class="alert alert-success mt-3 mb-0">
                        <i class="bi bi-check-circle"></i> Tijdrit gedownload!
                    </div>
                }
            </div>
        </div>
    </div>

    @* Losse tijdrit import *@
    <div class="col-md-6 mb-4">
        <div class="card h-100 border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-upload"></i> Tijdrit importeren</h5>
            </div>
            <div class="card-body">
                <p>Importeer een losse tijdrit uit een eerder geëxporteerd bestand.</p>

                <div class="mb-3">
                    <label class="form-label">Selecteer tijdrit bestand:</label>
                    <InputFile OnChange="OnTijdritFileSelected" class="form-control" accept=".json" />
                </div>

                @if (tijdritImportFileName != null)
                {
                    <div class="alert alert-info">
                        <strong>Geselecteerd:</strong> @tijdritImportFileName
                    </div>

                    <button class="btn btn-warning w-100" @onclick="AnalyseerTijdritImport" disabled="@isAnalysingTijdrit">
                        @if (isAnalysingTijdrit)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Analyseren...</span>
                        }
                        else
                        {
                            <i class="bi bi-search me-2"></i>
                            <span>Analyseer en importeer</span>
                        }
                    </button>
                }

                @if (importTijdritSucces)
                {
                    <div class="alert alert-success mt-3 mb-0">
                        <i class="bi bi-check-circle"></i> Tijdrit succesvol geïmporteerd!
                    </div>
                }

                @if (importTijdritError != null)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        <i class="bi bi-exclamation-triangle"></i> @importTijdritError
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* Reset sectie *@
<div class="row">
    <div class="col-12">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-trash"></i> Data resetten</h5>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <p class="mb-0">
                            <strong>Waarschuwing:</strong> Dit verwijdert <strong>alle</strong> deelnemers, tijdritten, resultaten en categorieën permanent. 
                            De seed data (voorbeelddata) wordt opnieuw geladen.
                        </p>
                    </div>
                    <div class="col-md-4 text-end">
                        <button class="btn btn-outline-danger" @onclick="ToonResetBevestiging">
                            <i class="bi bi-trash"></i> Reset alle data
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Reset bevestigingsmodal *@
@if (toonResetModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Alle data verwijderen?
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => toonResetModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger">
                        <strong><i class="bi bi-exclamation-octagon-fill"></i> WAARSCHUWING!</strong><br />
                        Je staat op het punt om ALLE data te verwijderen:
                    </div>

                    @if (exportStats != null)
                    {
                        <ul>
                            <li><strong>@exportStats.AantalDeelnemers</strong> deelnemers</li>
                            <li><strong>@exportStats.AantalTijdritten</strong> tijdritten</li>
                            <li><strong>@exportStats.AantalResultaten</strong> resultaten</li>
                            <li><strong>@exportStats.AantalCategorieen</strong> categorieën</li>
                        </ul>
                    }

                    <p class="text-danger mb-0">
                        <strong>Dit kan niet ongedaan worden gemaakt!</strong><br />
                        Maak eerst een backup als je de data wilt bewaren.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => toonResetModal = false">
                        <i class="bi bi-x-lg"></i> Annuleren
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ResetData">
                        <i class="bi bi-trash"></i> Ja, verwijder alles
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal: Ontbrekende deelnemers bij tijdrit import *@
@if (toonOntbrekendeDeelnemersModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-warning">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-person-exclamation me-2"></i>
                        Ontbrekende deelnemers gevonden
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => toonOntbrekendeDeelnemersModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>De volgende deelnemers uit de tijdrit bestaan nog niet in de app:</p>

                    <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                        <table class="table table-sm table-striped">
                            <thead class="table-warning">
                                <tr>
                                    <th>Naam</th>
                                    <th>Categorie</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in ontbrekendeDeelnemers)
                                {
                                    <tr>
                                        <td>@d.Naam</td>
                                        <td>@d.Categorie</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="alert alert-info mt-3 mb-0">
                        <strong>Wat wil je doen?</strong>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => toonOntbrekendeDeelnemersModal = false">
                        <i class="bi bi-x-lg"></i> Annuleren
                    </button>
                    <button type="button" class="btn btn-outline-warning" @onclick="ImporteerZonderOntbrekende">
                        <i class="bi bi-person-dash"></i> Alleen bestaande importeren
                    </button>
                    <button type="button" class="btn btn-success" @onclick="ImporteerMetNieuweDeelnemers">
                        <i class="bi bi-person-plus"></i> Deelnemers aanmaken
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal: Duplicaat tijdrit gevonden *@
@if (toonDuplicaatModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-warning">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Tijdrit bestaat al
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => toonDuplicaatModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>Er bestaat al een tijdrit op dezelfde datum:</p>

                    <div class="alert alert-warning">
                        <strong>@importTijdritData?.Tijdrit?.Datum.ToString("dd-MM-yyyy")</strong>
                        @if (!string.IsNullOrEmpty(importTijdritData?.Tijdrit?.Beschrijving))
                        {
                            <span> - @importTijdritData.Tijdrit.Beschrijving</span>
                        }
                    </div>

                    <p><strong>Wat wil je doen?</strong></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => toonDuplicaatModal = false">
                        <i class="bi bi-x-lg"></i> Annuleren
                    </button>
                    <button type="button" class="btn btn-primary" @onclick="ImporteerAlsNieuweTijdrit">
                        <i class="bi bi-plus-circle"></i> Als nieuwe tijdrit toevoegen
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="OverschrijfBestaandeTijdrit">
                        <i class="bi bi-arrow-repeat"></i> Bestaande overschrijven
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ExportStats? exportStats;
    private bool isExporting = false;
    private bool exportSucces = false;
    private bool isImporting = false;
    private bool importSucces = false;
    private string? importError = null;
    private string? selectedFileName = null;
    private string? selectedFileContent = null;
    private bool toonResetModal = false;

    // Losse tijdrit export
    private List<Tijdrit> alleTijdritten = new();
    private List<TijdritResultaat> alleResultaten = new();
    private List<Deelnemer> alleDeelnemers = new();
    private Guid geselecteerdeTijdritIdVoorExport = Guid.Empty;
    private bool isExportingTijdrit = false;
    private bool exportTijdritSucces = false;

    // Losse tijdrit import
    private string? tijdritImportFileName = null;
    private string? tijdritImportFileContent = null;
    private bool isAnalysingTijdrit = false;
    private bool importTijdritSucces = false;
    private string? importTijdritError = null;
    private TijdritExportData? importTijdritData = null;
    private List<DeelnemerInfo> ontbrekendeDeelnemers = new();
    private bool toonOntbrekendeDeelnemersModal = false;
    private bool toonDuplicaatModal = false;
    private Tijdrit? bestaandeDuplicaatTijdrit = null;
    private bool maakOntbrekendeDeelnemersAan = false;

    protected override async Task OnInitializedAsync()
    {
        await LaadStats();
        await LaadTijdrittenVoorExport();
    }

    private async Task LaadStats()
    {
        var deelnemers = await DataService.GetDeelnemersAsync();
        var tijdritten = await DataService.GetTijdrittenAsync();
        var resultaten = await DataService.GetResultatenAsync();
        var categorieen = await DataService.GetCategorieenAsync();

        exportStats = new ExportStats
        {
            AantalDeelnemers = deelnemers.Count,
            AantalTijdritten = tijdritten.Count,
            AantalResultaten = resultaten.Count,
            AantalCategorieen = categorieen.Count
        };
    }

    private async Task LaadTijdrittenVoorExport()
    {
        alleTijdritten = await DataService.GetTijdrittenAsync();
        alleResultaten = await DataService.GetResultatenAsync();
        alleDeelnemers = await DataService.GetDeelnemersAsync();
    }

    private async Task ExporteerData()
    {
        isExporting = true;
        exportSucces = false;
        StateHasChanged();

        try
        {
            var exportData = new ExportData
            {
                ExportDatum = DateTime.Now,
                Versie = "1.0",
                Deelnemers = await DataService.GetDeelnemersAsync(),
                Tijdritten = await DataService.GetTijdrittenAsync(),
                Resultaten = await DataService.GetResultatenAsync(),
                Categorieen = await DataService.GetCategorieenAsync()
            };

            var json = JsonSerializer.Serialize(exportData, new JsonSerializerOptions 
            { 
                WriteIndented = true 
            });

            var fileName = $"nwvg-tijdrit-backup-{DateTime.Now:yyyy-MM-dd-HHmmss}.json";

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, json);

            exportSucces = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Export fout: {ex.Message}");
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        importSucces = false;
        importError = null;
        selectedFileName = null;
        selectedFileContent = null;

        try
        {
            var file = e.File;
            if (file != null)
            {
                selectedFileName = file.Name;
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var reader = new StreamReader(stream);
                selectedFileContent = await reader.ReadToEndAsync();
            }
        }
        catch (Exception ex)
        {
            importError = $"Fout bij lezen bestand: {ex.Message}";
        }
    }

    private async Task ImporteerData()
    {
        if (string.IsNullOrEmpty(selectedFileContent))
        {
            importError = "Geen bestand geselecteerd.";
            return;
        }

        isImporting = true;
        importSucces = false;
        importError = null;
        StateHasChanged();

        try
        {
            var importData = JsonSerializer.Deserialize<ExportData>(selectedFileContent);

            if (importData == null)
            {
                importError = "Ongeldig backup bestand.";
                return;
            }

            await DataService.ImportDataAsync(
                importData.Deelnemers ?? new List<Deelnemer>(),
                importData.Tijdritten ?? new List<Tijdrit>(),
                importData.Resultaten ?? new List<TijdritResultaat>(),
                importData.Categorieen ?? new List<string>()
            );

            importSucces = true;
            selectedFileName = null;
            selectedFileContent = null;

            await LaadStats();
            await LaadTijdrittenVoorExport();
        }
        catch (JsonException)
        {
            importError = "Ongeldig JSON formaat. Is dit wel een NWVG Tijdrit backup bestand?";
        }
        catch (Exception ex)
        {
            importError = $"Import fout: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }

    private void ToonResetBevestiging()
    {
        toonResetModal = true;
    }

    private async Task ResetData()
    {
        toonResetModal = false;

        await DataService.ResetAllDataAsync();
        await LaadStats();
        await LaadTijdrittenVoorExport();
    }

    // === Losse tijdrit export ===
    private async Task ExporteerLosseTijdrit()
    {
        if (geselecteerdeTijdritIdVoorExport == Guid.Empty) return;

        isExportingTijdrit = true;
        exportTijdritSucces = false;
        StateHasChanged();

        try
        {
            var tijdrit = alleTijdritten.FirstOrDefault(t => t.Id == geselecteerdeTijdritIdVoorExport);
            if (tijdrit == null) return;

            var resultaten = alleResultaten.Where(r => r.TijdritId == tijdrit.Id).ToList();

            // Verzamel deelnemer info voor de resultaten
            var deelnemerInfos = new List<DeelnemerInfo>();
            foreach (var resultaat in resultaten)
            {
                var deelnemer = alleDeelnemers.FirstOrDefault(d => d.Id == resultaat.DeelnemerId);
                if (deelnemer != null && !deelnemerInfos.Any(di => di.OrigineleId == deelnemer.Id))
                {
                    deelnemerInfos.Add(new DeelnemerInfo
                    {
                        OrigineleId = deelnemer.Id,
                        Naam = deelnemer.Naam,
                        Categorie = deelnemer.Categorie
                    });
                }
            }

            var exportData = new TijdritExportData
            {
                ExportDatum = DateTime.Now,
                Versie = "1.0",
                Tijdrit = tijdrit,
                Resultaten = resultaten,
                DeelnemerInfos = deelnemerInfos
            };

            var json = JsonSerializer.Serialize(exportData, new JsonSerializerOptions { WriteIndented = true });
            var beschrijving = !string.IsNullOrEmpty(tijdrit.Beschrijving) ? tijdrit.Beschrijving.Replace(" ", "-") : "tijdrit";
            var fileName = $"tijdrit-{tijdrit.Datum:yyyy-MM-dd}-{beschrijving}.json";

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, json);

            exportTijdritSucces = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Export tijdrit fout: {ex.Message}");
        }
        finally
        {
            isExportingTijdrit = false;
        }
    }

    // === Losse tijdrit import ===
    private async Task OnTijdritFileSelected(InputFileChangeEventArgs e)
    {
        importTijdritSucces = false;
        importTijdritError = null;
        tijdritImportFileName = null;
        tijdritImportFileContent = null;

        try
        {
            var file = e.File;
            if (file != null)
            {
                tijdritImportFileName = file.Name;
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var reader = new StreamReader(stream);
                tijdritImportFileContent = await reader.ReadToEndAsync();
            }
        }
        catch (Exception ex)
        {
            importTijdritError = $"Fout bij lezen bestand: {ex.Message}";
        }
    }

    private async Task AnalyseerTijdritImport()
    {
        if (string.IsNullOrEmpty(tijdritImportFileContent))
        {
            importTijdritError = "Geen bestand geselecteerd.";
            return;
        }

        isAnalysingTijdrit = true;
        importTijdritError = null;
        StateHasChanged();

        try
        {
            importTijdritData = JsonSerializer.Deserialize<TijdritExportData>(tijdritImportFileContent);

            if (importTijdritData?.Tijdrit == null)
            {
                importTijdritError = "Ongeldig tijdrit bestand.";
                return;
            }

            // Check voor duplicaat tijdrit (zelfde datum)
            bestaandeDuplicaatTijdrit = alleTijdritten.FirstOrDefault(t => 
                t.Datum.Date == importTijdritData.Tijdrit.Datum.Date);

            // Check voor ontbrekende deelnemers
            ontbrekendeDeelnemers.Clear();
            if (importTijdritData.DeelnemerInfos != null)
            {
                foreach (var info in importTijdritData.DeelnemerInfos)
                {
                    var bestaand = alleDeelnemers.FirstOrDefault(d => 
                        d.Naam.Equals(info.Naam, StringComparison.OrdinalIgnoreCase));
                    if (bestaand == null)
                    {
                        ontbrekendeDeelnemers.Add(info);
                    }
                }
            }

            // Toon juiste modal
            if (ontbrekendeDeelnemers.Any())
            {
                toonOntbrekendeDeelnemersModal = true;
            }
            else if (bestaandeDuplicaatTijdrit != null)
            {
                toonDuplicaatModal = true;
            }
            else
            {
                await VoerTijdritImportUit(false, false);
            }
        }
        catch (JsonException)
        {
            importTijdritError = "Ongeldig JSON formaat. Is dit wel een NWVG Tijdrit export bestand?";
        }
        catch (Exception ex)
        {
            importTijdritError = $"Analyse fout: {ex.Message}";
        }
        finally
        {
            isAnalysingTijdrit = false;
        }
    }

    private async Task ImporteerZonderOntbrekende()
    {
        toonOntbrekendeDeelnemersModal = false;
        maakOntbrekendeDeelnemersAan = false;

        if (bestaandeDuplicaatTijdrit != null)
        {
            toonDuplicaatModal = true;
        }
        else
        {
            await VoerTijdritImportUit(false, false);
        }
    }

