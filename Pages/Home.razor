@page "/"

<PageTitle>NWVG Tijdrit</PageTitle>

<div class="text-center mb-4">
    <img src="images/logo-nwvg.png" alt="NWVG Logo" style="max-height: 120px;" class="mb-2" onerror="this.style.display='none'" />
    <h1>Noordelijke Wielervereniging Groningen</h1>
    <p class="lead text-muted">Tijdrit Applicatie</p>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-success">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-people-fill text-success"></i> Deelnemers</h5>
                <p class="card-text">Beheer de renners die kunnen deelnemen aan tijdritten.</p>
                <a href="deelnemers" class="btn btn-success">Naar Deelnemers</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-danger">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-stopwatch text-danger"></i> Tijdritten</h5>
                <p class="card-text">Start een nieuwe tijdrit en voer passagetijden in.</p>
                <a href="tijdritten" class="btn btn-danger">Naar Tijdritten</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-primary">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-trophy text-primary"></i> Uitslagen</h5>
                <p class="card-text">Bekijk resultaten en klassementen per categorie.</p>
                <a href="uitslagen" class="btn btn-primary">Naar Uitslagen</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-12">
        <div class="alert alert-light border">
            <h5><i class="bi bi-info-circle"></i> Over deze applicatie</h5>
            <ul class="mb-0">
                <li><strong>Rondelengte:</strong> 1.6 km (standaard)</li>
                <li><strong>Categorieen:</strong> Gebaseerd op leeftijd + geslacht</li>
                <li><strong>Data-opslag:</strong> Lokaal in je browser (werkt offline!)</li>
            </ul>
        </div>
    </div>
</div>
