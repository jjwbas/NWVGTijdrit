@page "/uitslagen"
@page "/uitslagen/{TijdritIdParam}"
@using NWVGTijdrit.Data
@inject DataService DataService
@inject NavigationManager NavigationManager

<PageTitle>Uitslagen - NWVG Tijdrit</PageTitle>

<h1><i class="bi bi-trophy"></i> Uitslagen</h1>

@if (huidigeTijdrit == null)
{
    @* Selecteer een tijdrit *@
    <p class="lead">Selecteer een tijdrit om de uitslagen te bekijken.</p>

    @if (!tijdritten.Any())
    {
        <div class="alert alert-info">
            <strong>Nog geen tijdritten!</strong> 
            <a href="tijdritten">Start eerst een tijdrit</a> en voer resultaten in.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var tijdrit in tijdritten.OrderByDescending(t => t.Datum))
            {
                var aantalDeelnemers = resultatenPerTijdrit.GetValueOrDefault(tijdrit.Id, 0);
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@tijdrit.Datum.ToString("dd MMMM yyyy")</h5>
                            <p class="card-text">
                                @if (!string.IsNullOrEmpty(tijdrit.Beschrijving))
                                {
                                    <span>@tijdrit.Beschrijving</span><br />
                                }
                                <small class="text-muted">
                                    @aantalDeelnemers deelnemer(s) - @tijdrit.RondeLengteKm km/ronde
                                </small>
                            </p>
                            <a href="uitslagen/@tijdrit.Id" class="btn btn-primary">
                                Bekijk uitslagen
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
else
{
    @* Uitslagen van specifieke tijdrit *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <span class="badge bg-primary fs-6 me-2">@huidigeTijdrit.Datum.ToString("dd MMMM yyyy")</span>
            @if (!string.IsNullOrEmpty(huidigeTijdrit.Beschrijving))
            {
                <span class="text-muted">@huidigeTijdrit.Beschrijving</span>
            }
        </div>
        <div>
            <button class="btn btn-outline-secondary me-2" @onclick="NaarOverzicht">
                <i class="bi bi-arrow-left"></i> Terug naar overzicht
            </button>
            <button class="btn btn-outline-primary" @onclick="PrintUitslagen">
                <i class="bi bi-printer"></i> Printen
            </button>
        </div>
    </div>

    @if (!resultaten.Any())
    {
        <div class="alert alert-warning">
            <strong>Geen resultaten!</strong> 
            <a href="tijdritten/@huidigeTijdrit.Id">Voer eerst passagetijden in</a>.
        </div>
    }
    else
    {
        @* Algemene statistieken *@
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@resultaten.Count</h3>
                        <small class="text-muted">Deelnemers</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@categorien.Count()</h3>
                        <small class="text-muted">Categorieen</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@resultatenCompleet.Count()</h3>
                        <small class="text-muted">Gefinisht</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-light">
                    <div class="card-body text-center">
                        @if (snelsteGemiddelde != null)
                        {
                            <h3 class="mb-0">@snelsteGemiddelde.Value.ToString("F1") km/u</h3>
                            <small class="text-muted">Snelste gem.</small>
                        }
                        else
                        {
                            <h3 class="mb-0">-</h3>
                            <small class="text-muted">Snelste gem.</small>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Filter op categorie *@
        <div class="mb-3 d-flex gap-3 align-items-center">
            <div>
                <label class="form-label mb-0 me-2">Filter op categorie:</label>
                <select class="form-select form-select-sm w-auto d-inline-block" value="@filterCategorie" @onchange="OnCategorieFilterChanged">
                    <option value="">Alle categorieën</option>
                    @foreach (var cat in categorien)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
        </div>

        @* Één grote resultatenlijst *@
        <div class="card mb-4">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-list-ol"></i> Resultaten
                    @if (!string.IsNullOrEmpty(filterCategorie))
                    {
                        <span class="badge bg-info ms-2">@filterCategorie</span>
                    }
                    <span class="badge bg-light text-dark ms-2">@gefilterdeResultaten.Count() deelnemers</span>
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            @if (string.IsNullOrEmpty(filterCategorie))
                            {
                                <th style="width: 70px; cursor: pointer;" @onclick="() => SorteerOp(SorteerKolom.Startnr)">
                                    Startnr @SorteerIndicator(SorteerKolom.Startnr)
                                </th>
                            }
                            else
                            {
                                <th style="width: 70px; cursor: pointer;" @onclick="() => SorteerOp(SorteerKolom.Plaats)">
                                    Plaats @SorteerIndicator(SorteerKolom.Plaats)
                                </th>
                            }
                            <th style="cursor: pointer;" @onclick="() => SorteerOp(SorteerKolom.Naam)">
                                Naam @SorteerIndicator(SorteerKolom.Naam)
                            </th>
                            @if (string.IsNullOrEmpty(filterCategorie))
                            {
                                <th style="cursor: pointer;" @onclick="() => SorteerOp(SorteerKolom.Categorie)">
                                    Categorie @SorteerIndicator(SorteerKolom.Categorie)
                                </th>
                            }
                            <th style="width: 80px; cursor: pointer;" @onclick="() => SorteerOp(SorteerKolom.Rondes)">
                                Rondes @SorteerIndicator(SorteerKolom.Rondes)
                            </th>
                            <th style="cursor: pointer;" @onclick="() => SorteerOp(SorteerKolom.Tijd)">
                                Netto tijd @SorteerIndicator(SorteerKolom.Tijd)
                            </th>
                            <th>Afstand</th>
                            <th style="cursor: pointer;" @onclick="() => SorteerOp(SorteerKolom.Snelheid)">
                                Gem. snelheid @SorteerIndicator(SorteerKolom.Snelheid)
                            </th>
                            <th>Rondetijden</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var plaats = 0; }
                        @foreach (var item in gesorteerdeResultaten)
                        {
                            plaats++;
                            var isCompleet = item.Resultaat.Passagetijden.Count >= item.Resultaat.AantalRondes;

                            <tr class="@(!isCompleet ? "table-warning" : "")">
                                @if (string.IsNullOrEmpty(filterCategorie))
                                {
                                    <td><strong>@item.Resultaat.Startvolgorde</strong></td>
                                }
                                else
                                {
                                    <td><strong>@plaats.</strong></td>
                                }
                                <td>@item.Deelnemer.Naam</td>
                                @if (string.IsNullOrEmpty(filterCategorie))
                                {
                                    <td><span class="badge bg-secondary">@item.Deelnemer.Categorie</span></td>
                                }
                                <td>@item.Resultaat.AantalRondes</td>
                                <td class="font-monospace">
                                    @if (item.Resultaat.NettoTijd > TimeSpan.Zero)
                                    {
                                        <strong>@FormatTijd(item.Resultaat.NettoTijd)</strong>
                                    }
                                    else
                                    {
                                        <span class="text-muted">DNF</span>
                                    }
                                </td>
                                <td>@item.Resultaat.AfstandKm(huidigeTijdrit.RondeLengteKm).ToString("F1") km</td>
                                <td>
                                    @if (item.Resultaat.GemiddeldeSnelheid(huidigeTijdrit.RondeLengteKm) > 0)
                                    {
                                        <span>@item.Resultaat.GemiddeldeSnelheid(huidigeTijdrit.RondeLengteKm).ToString("F1") km/u</span>
                                    }
                                </td>
                                <td class="font-monospace" style="font-size: 0.85rem;">
                                    @if (item.Resultaat.HeeftEchteRondetijden)
                                    {
                                        @string.Join(" / ", item.Resultaat.Rondetijden.Select(r => FormatRondetijd(r)))
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public string? TijdritIdParam { get; set; }

    private List<Tijdrit> tijdritten = new();
    private Dictionary<Guid, int> resultatenPerTijdrit = new();

    private Tijdrit? huidigeTijdrit;
    private List<TijdritResultaat> resultaten = new();
    private List<Deelnemer> alleDeelnemers = new();

    private string filterCategorie = "";

    // Sortering
    private SorteerKolom huidigeSortering = SorteerKolom.Startnr;
    private bool sorteerOplopend = true;

    private enum SorteerKolom { Startnr, Plaats, Naam, Categorie, Rondes, Tijd, Snelheid }

    private IEnumerable<string> categorien => resultaten
        .Select(r => alleDeelnemers.FirstOrDefault(d => d.Id == r.DeelnemerId)?.Categorie)
        .Where(c => !string.IsNullOrEmpty(c))
        .Distinct()
        .OrderBy(c => c)!;

    private IEnumerable<TijdritResultaat> resultatenCompleet => 
        resultaten.Where(r => r.Passagetijden.Count >= r.AantalRondes && r.NettoTijd > TimeSpan.Zero);

    private double? snelsteGemiddelde => resultatenCompleet.Any() && huidigeTijdrit != null
        ? resultatenCompleet.Max(r => r.GemiddeldeSnelheid(huidigeTijdrit.RondeLengteKm))
        : null;

    // Gefilterde resultaten (op categorie)
    private IEnumerable<(TijdritResultaat Resultaat, Deelnemer Deelnemer)> gefilterdeResultaten =>
        resultaten
            .Select(r => (Resultaat: r, Deelnemer: alleDeelnemers.FirstOrDefault(d => d.Id == r.DeelnemerId)))
            .Where(x => x.Deelnemer != null)
            .Where(x => string.IsNullOrEmpty(filterCategorie) || x.Deelnemer!.Categorie == filterCategorie)
            .Select(x => (x.Resultaat, x.Deelnemer!));

    // Gesorteerde resultaten
    private IEnumerable<(TijdritResultaat Resultaat, Deelnemer Deelnemer)> gesorteerdeResultaten
    {
        get
        {
            var data = gefilterdeResultaten;

            IOrderedEnumerable<(TijdritResultaat Resultaat, Deelnemer Deelnemer)> sorted = huidigeSortering switch
            {
                SorteerKolom.Startnr => sorteerOplopend 
                    ? data.OrderBy(x => x.Resultaat.Startvolgorde)
                    : data.OrderByDescending(x => x.Resultaat.Startvolgorde),

                SorteerKolom.Naam => sorteerOplopend 
                    ? data.OrderBy(x => x.Deelnemer.Naam)
                    : data.OrderByDescending(x => x.Deelnemer.Naam),

                SorteerKolom.Categorie => sorteerOplopend 
                    ? data.OrderBy(x => x.Deelnemer.Categorie)
                    : data.OrderByDescending(x => x.Deelnemer.Categorie),

                SorteerKolom.Rondes => sorteerOplopend 
                    ? data.OrderBy(x => x.Resultaat.AantalRondes)
                    : data.OrderByDescending(x => x.Resultaat.AantalRondes),

                SorteerKolom.Tijd => sorteerOplopend 
                    ? data.OrderBy(x => x.Resultaat.NettoTijd > TimeSpan.Zero ? x.Resultaat.NettoTijd : TimeSpan.MaxValue)
                    : data.OrderByDescending(x => x.Resultaat.NettoTijd),

                SorteerKolom.Snelheid => sorteerOplopend 
                    ? data.OrderBy(x => x.Resultaat.GemiddeldeSnelheid(huidigeTijdrit?.RondeLengteKm ?? 1.6))
                    : data.OrderByDescending(x => x.Resultaat.GemiddeldeSnelheid(huidigeTijdrit?.RondeLengteKm ?? 1.6)),

                // Plaats = sortering op klassement: eerst gefinisht, dan op netto tijd
                _ => sorteerOplopend 
                    ? data.OrderBy(x => 
                    {
                        var isCompleet = x.Resultaat.Passagetijden.Count >= x.Resultaat.AantalRondes;
                        if (!isCompleet) return TimeSpan.MaxValue;
                        return x.Resultaat.NettoTijd;
                    })
                    : data.OrderByDescending(x => x.Resultaat.NettoTijd)
            };

            return sorted;
        }
    }

    private void SorteerOp(SorteerKolom kolom)
    {
        if (huidigeSortering == kolom)
        {
            // Zelfde kolom: toggle richting
            sorteerOplopend = !sorteerOplopend;
        }
        else
        {
            // Andere kolom: nieuwe sortering, default richting
            huidigeSortering = kolom;
            // Voor snelheid default aflopend (snelste eerst), rest oplopend
            sorteerOplopend = kolom != SorteerKolom.Snelheid;
        }
    }

    private string SorteerIndicator(SorteerKolom kolom)
    {
        if (huidigeSortering != kolom) return "";
        return sorteerOplopend ? "▲" : "▼";
    }

    protected override async Task OnInitializedAsync()
    {
        await LaadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reageer op wijzigingen in de URL parameter
        if (Guid.TryParse(TijdritIdParam, out var tijdritId))
        {
            // Alleen laden als het een andere tijdrit is
            if (huidigeTijdrit?.Id != tijdritId)
            {
                var tijdrit = tijdritten.FirstOrDefault(t => t.Id == tijdritId);
                if (tijdrit != null)
                {
                    await SelecteerTijdrit(tijdrit);
                }
            }
        }
        else
        {
            // Geen parameter = terug naar overzicht
            huidigeTijdrit = null;
            resultaten.Clear();
        }
    }

    private async Task LaadData()
    {
        tijdritten = await DataService.GetTijdrittenAsync();
        alleDeelnemers = await DataService.GetDeelnemersAsync();

        var alleResultaten = await DataService.GetResultatenAsync();
        resultatenPerTijdrit = alleResultaten
            .GroupBy(r => r.TijdritId)
            .ToDictionary(g => g.Key, g => g.Count());
    }

    private async Task SelecteerTijdrit(Tijdrit tijdrit)
    {
        huidigeTijdrit = tijdrit;
        resultaten = await DataService.GetResultatenVoorTijdritAsync(tijdrit.Id);
        // Reset sortering bij nieuwe tijdrit (default = startnummer)
        huidigeSortering = SorteerKolom.Startnr;
        sorteerOplopend = true;
        filterCategorie = "";
    }

    private void NaarOverzicht()
    {
        NavigationManager.NavigateTo("/uitslagen");
    }

    private void OnCategorieFilterChanged(ChangeEventArgs e)
    {
        filterCategorie = e.Value?.ToString() ?? "";

        // Bij selectie van een categorie: sorteer automatisch op snelste tijd (Plaats)
        if (!string.IsNullOrEmpty(filterCategorie))
        {
            huidigeSortering = SorteerKolom.Plaats;
            sorteerOplopend = true;
        }
        else
        {
            // Terug naar alle categorieën: reset naar startnummer
            huidigeSortering = SorteerKolom.Startnr;
            sorteerOplopend = true;
        }
    }

    private void PrintUitslagen()
    {
        // In een echte app zou je hier JavaScript interop gebruiken
        // Voor nu gewoon window.print() aanroepen
    }

    private string FormatTijd(TimeSpan tijd)
    {
        if (tijd.TotalHours >= 1)
            return tijd.ToString(@"h\:mm\:ss\.f");
        return tijd.ToString(@"mm\:ss\.f");
    }

    private string FormatTijdKort(TimeSpan tijd)
    {
        if (tijd.TotalMinutes >= 10)
            return tijd.ToString(@"mm\:ss");
        return tijd.ToString(@"m\:ss\.f");
    }

    private string FormatRondetijd(TimeSpan tijd)
    {
        // Ontbrekende rondetijd (Zero) tonen als streepje
        if (tijd == TimeSpan.Zero)
            return "-";
        if (tijd.TotalMinutes >= 10)
            return tijd.ToString(@"mm\:ss");
        return tijd.ToString(@"m\:ss");
    }
}
